DEEPSEEK_API_KEY=your_api_key_here

# PostgreSQL connection string (enables instant DB lookups)
# Without this, the server runs in LLM-only mode (all requests go to DeepSeek)
DATABASE_URL=postgresql://polyglot:password@localhost:5432/polyglot

# Set this when running frontend locally but backend on a remote server
# Leave empty/unset when frontend and backend are on the same origin
VITE_API_URL=
